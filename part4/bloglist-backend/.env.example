# =============================================================================
# ENVIRONMENT VARIABLES - Configuration for Bloglist Backend
# =============================================================================
#
# This file contains environment variables that the application uses.
# Create a copy of this file named '.env' and fill in your actual values.
#
# IMPORTANT: Never commit .env files to version control!
# Add '.env' to your .gitignore file.
#
# =============================================================================
# SETUP INSTRUCTIONS
# =============================================================================
#
# 1. Copy this file to .env:
#    cp .env.example .env
#
# 2. For local development, you need:
#    - MongoDB installed locally, OR
#    - A MongoDB Atlas account (cloud database)
#
# 3. If using MongoDB Atlas, your connection string looks like:
#    mongodb+srv://username:password@cluster.mongodb.net/bloglist
#
# =============================================================================
# PORT
# =============================================================================
# The port number where the backend server will run
# Default: 3001 (good choice to avoid conflict with React on 3000)
PORT=3001

# =============================================================================
# MONGODB URI
# =============================================================================
# Connection string for your MongoDB database
#
# Local development:
# MONGODB_URI=mongodb://localhost:27017/bloglist
#
# MongoDB Atlas (cloud):
# MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/bloglist
#
# Testing (used when NODE_ENV=test):
# TEST_MONGODB_URI=mongodb://localhost:27017/bloglist_test
MONGODB_URI=mongodb://localhost:27017/bloglist

# =============================================================================
# JWT SECRET
# =============================================================================
# Secret key used to sign JSON Web Tokens (JWT)
# This is used for authentication - keep it secret!
#
# In production:
# - Use a long, random string
# - Never commit to version control
# - Consider using a secrets manager
#
# Example: Generate a random secret with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
SECRET=your-super-secret-jwt-key-change-this-in-production

# =============================================================================
# TEST DATABASE (optional - only needed for running tests)
# =============================================================================
TEST_MONGODB_URI=mongodb://localhost:27017/bloglist_test

# =============================================================================
# HOW TO RUN
# =============================================================================
#
# Development (auto-restart on changes):
#   npm run dev
#
# Production:
#   npm start
#
# Run tests:
#   npm test
#
# =============================================================================